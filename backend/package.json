{
  "name": "brewski-bets-backend",
  "version": "1.12.0",
  "description": "Backend API for brewski bets",
  "author": "Michal Wiraszka",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "tunnel": "ngrok http 3000",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**' 'api/**'",
    "format": "prettier --write 'src/**/*.ts' 'api/**/*.ts'",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1089.0",
    "@clerk/backend": "3.11.7",
    "@hono/node-server": "2.0.10",
    "@hono/zod-validator": "0.9.0",
    "@neondatabase/serverless": "1.1.0",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.30",
    "svix": "1.97.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/node": "26.1.1",
    "drizzle-kit": "0.31.10",
    "eslint": "10.7.0",
    "eslint-plugin-import-x": "4.17.1",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0"
  },
  "engines": {
    "node": "^22.22.3 || ^24.15.0 || >=26.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.28.1",
      "fast-xml-parser": ">=5.7.0",
      "fast-xml-builder": ">=1.1.7",
      "lodash-es": ">=4.18.0",
      "js-cookie": ">=3.0.7"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "react"
      ]
    },
    "onlyBuiltDependencies": [
      "@clerk/shared",
      "esbuild"
    ]
  }
}
