{
  "name": "brewski-bets",
  "description": "Frontend for brewski bets, built with Angular",
  "author": "Michal Wiraszka",
  "private": true,
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/mwiraszka/brewski-bets.git"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve -o",
    "start:prod": "ng serve -o --configuration production",
    "build:dev": "ng build",
    "build:preview": "ng build --configuration preview",
    "build:prod": "ng build --configuration production",
    "build:stats": "ng build --stats-json && webpack-bundle-analyzer dist/stats.json",
    "watch": "ng build --watch --configuration development",
    "lint": "eslint 'src/**'",
    "test": "jest"
  },
  "dependencies": {
    "@angular/cdk": "21.2.4",
    "@angular/common": "21.2.6",
    "@angular/compiler": "21.2.6",
    "@angular/core": "21.2.6",
    "@angular/forms": "21.2.6",
    "@angular/platform-browser": "21.2.6",
    "@angular/platform-browser-dynamic": "21.2.6",
    "@angular/router": "21.2.6",
    "@clerk/clerk-js": "6.3.3",
    "@eagami/ui": "0.6.0",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.2.5",
    "@angular/cli": "21.2.5",
    "@angular/compiler-cli": "21.2.6",
    "@eslint/js": "10.0.1",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "eslint": "10.1.0",
    "globals": "17.4.0",
    "prettier": "3.8.1",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "@types/jest": "30.0.0",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "jest-preset-angular": "16.1.1",
    "typescript-eslint": "8.57.2"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "pnpm": {
    "overrides": {
      "undici": ">=7.24.0"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "utf-8-validate": "6",
        "bs58": "5"
      }
    }
  }
}
