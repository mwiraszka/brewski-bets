{
  "name": "brewski-bets",
  "version": "1.6.1",
  "description": "Frontend for brewski bets, built with Angular",
  "author": "Michal Wiraszka",
  "private": true,
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/mwiraszka/brewski-bets.git"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve -o",
    "start:prod": "ng serve -o --configuration production",
    "build:dev": "ng build",
    "build:preview": "ng build --configuration preview",
    "build:prod": "ng build --configuration production",
    "build:stats": "ng build --stats-json && webpack-bundle-analyzer dist/stats.json",
    "watch": "ng build --watch --configuration development",
    "format": "prettier --write 'src/**/*.{ts,html,scss}'",
    "lint": "eslint 'src/**'",
    "test": "ng test"
  },
  "dependencies": {
    "@angular/cdk": "22.0.3",
    "@angular/common": "22.0.5",
    "@angular/compiler": "22.0.5",
    "@angular/core": "22.0.5",
    "@angular/forms": "22.0.5",
    "@angular/platform-browser": "22.0.5",
    "@angular/router": "22.0.5",
    "@clerk/clerk-js": "6.23.0",
    "@eagami/ui": "5.2.0",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.2"
  },
  "devDependencies": {
    "@angular/build": "22.0.5",
    "@angular/cli": "22.0.5",
    "@angular/compiler-cli": "22.0.5",
    "@eslint/js": "10.0.1",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "eslint": "10.6.0",
    "eslint-plugin-import-x": "4.17.1",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": "^22.22.3 || ^24.15.0 || >=26.0.0"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "pnpm": {
    "overrides": {
      "undici": ">=7.24.0 <8",
      "path-to-regexp@~0.1.12": "0.1.13",
      "path-to-regexp@^8.0.0": "8.4.2",
      "picomatch@^2.3.1": "2.3.2",
      "serialize-javascript@^7.0.3": "7.0.5",
      "brace-expansion@^1.1.7": "1.1.13",
      "brace-expansion@^2.0.2": "2.0.3",
      "brace-expansion@^5.0.2": "5.0.6",
      "lodash@>=4.17.21": "4.18.1",
      "lodash-es@^4.17.21": "4.18.1",
      "vite": ">=7.3.2 <8",
      "piscina": ">=5.2.0",
      "tar": ">=7.5.16",
      "js-yaml": ">=4.2.0",
      "@babel/core": "7.29.7",
      "fast-uri": ">=3.1.2",
      "hono": ">=4.12.25",
      "esbuild": ">=0.28.1",
      "shell-quote": ">=1.8.4",
      "@hono/node-server": ">=1.19.13",
      "postcss": ">=8.5.10",
      "ip-address": ">=10.1.1",
      "uuid@^11.0.0": ">=11.1.1",
      "uuid@^8.3.2": ">=11.1.1",
      "follow-redirects": ">=1.16.0",
      "@babel/plugin-transform-modules-systemjs": ">=7.29.4",
      "js-cookie": ">=3.0.7",
      "webpack-dev-server": ">=5.2.4",
      "ws": ">=8.20.1",
      "qs": ">=6.15.2",
      "sigstore": ">=4.1.1",
      "@sigstore/core": ">=3.2.1",
      "@sigstore/verify": ">=3.1.1"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "utf-8-validate": "6",
        "bs58": "5"
      }
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "lmdb",
      "msgpackr-extract"
    ]
  }
}
