{
  "name": "brewski-bets",
  "version": "1.0.0",
  "description": "Frontend for brewski bets, built with Angular",
  "author": "Michal Wiraszka",
  "private": true,
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/mwiraszka/brewski-bets.git"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve -o",
    "start:prod": "ng serve -o --configuration production",
    "build:dev": "ng build",
    "build:preview": "ng build --configuration preview",
    "build:prod": "ng build --configuration production",
    "build:stats": "ng build --stats-json && webpack-bundle-analyzer dist/stats.json",
    "watch": "ng build --watch --configuration development",
    "format": "prettier --write 'src/**/*.{ts,html,scss}'",
    "lint": "eslint 'src/**'",
    "test": "jest"
  },
  "dependencies": {
    "@angular/cdk": "21.2.13",
    "@angular/common": "21.2.15",
    "@angular/compiler": "21.2.15",
    "@angular/core": "21.2.15",
    "@angular/forms": "21.2.15",
    "@angular/platform-browser": "21.2.15",
    "@angular/platform-browser-dynamic": "21.2.15",
    "@angular/router": "21.2.15",
    "@clerk/clerk-js": "6.13.0",
    "@eagami/ui": "2.5.1",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.2.13",
    "@angular/cli": "21.2.13",
    "@angular/compiler-cli": "21.2.15",
    "@eslint/js": "10.0.1",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/jest": "30.0.0",
    "eslint": "10.4.1",
    "eslint-plugin-import-x": "4.16.2",
    "globals": "17.6.0",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "jest-preset-angular": "16.1.5",
    "prettier": "3.8.3",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.0"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "pnpm": {
    "overrides": {
      "undici": ">=7.24.0",
      "path-to-regexp@~0.1.12": "0.1.13",
      "path-to-regexp@^8.0.0": "8.4.2",
      "picomatch@^2.3.1": "2.3.2",
      "serialize-javascript@^7.0.3": "7.0.5",
      "brace-expansion@^1.1.7": "1.1.13",
      "brace-expansion@^2.0.2": "2.0.3",
      "brace-expansion@^5.0.2": "5.0.6",
      "lodash@>=4.17.21": "4.18.1",
      "lodash-es@^4.17.21": "4.18.1",
      "vite": ">=7.3.2",
      "fast-uri": ">=3.1.2",
      "hono": ">=4.12.18",
      "@hono/node-server": ">=1.19.13",
      "postcss": ">=8.5.10",
      "ip-address": ">=10.1.1",
      "uuid@^11.0.0": ">=11.1.1",
      "uuid@^8.3.2": ">=11.1.1",
      "follow-redirects": ">=1.16.0",
      "@babel/plugin-transform-modules-systemjs": ">=7.29.4",
      "js-cookie": ">=3.0.7",
      "webpack-dev-server": ">=5.2.4",
